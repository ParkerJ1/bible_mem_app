# ── Text provider ──────────────────────────────────────────────────────────────
TEXT_PROVIDER=web           # "web" (World English Bible) or "esv"

# ESV API — required only when TEXT_PROVIDER=esv
# Obtain a key at https://api.esv.org/
ESV_API_KEY=your_esv_api_key_here

# ── TTS provider ───────────────────────────────────────────────────────────────
TTS_PROVIDER=google         # "google" or "elevenlabs" or "esv"

# Google Cloud Text-to-Speech API key
# Enable the Cloud TTS API and create a key at https://console.cloud.google.com/
GOOGLE_TTS_KEY=your_google_tts_api_key_here

# ElevenLabs API key — required only when TTS_PROVIDER=elevenlabs
# Obtain a key at https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── Speech recognition ─────────────────────────────────────────────────────────
WHISPER_MODEL=base          # "tiny", "base", "small", "medium"

# ── Scoring ────────────────────────────────────────────────────────────────────
SCORING_MODE=strict         # "strict" (exact match) or "lenient" (lemmatised, ignores tense/plural)

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./bible_mem.db
